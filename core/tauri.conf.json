{
  "$schema": "https://schema.tauri.app/config/2",
  "build": {
    "frontendDist": "../web/dist"
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:zettl.db"]
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "security": {
      "capabilities": ["global-shortcut:allow-register"]
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ]
  },
  "identifier": "io.zettl.app",
  "productName": "Zettl"
}
